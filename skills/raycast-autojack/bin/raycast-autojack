#!/usr/bin/env bash
set -euo pipefail

action="${1:-doctor}"
if [[ $# -gt 0 ]]; then
  shift
fi

repo="."
dry_run="false"
json="false"
passthrough=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)
      repo="${2:?--repo requires a path}"
      shift 2
      ;;
    --dry-run)
      dry_run="true"
      shift
      ;;
    --json)
      json="true"
      shift
      ;;
    --)
      shift
      passthrough+=("$@")
      break
      ;;
    *)
      passthrough+=("$1")
      shift
      ;;
  esac
done

repo="$(cd "$repo" && pwd)"

emit() {
  if [[ "$json" == "true" ]]; then
    printf '{"skill":"raycast-autojack","action":"%s","repo":"%s","message":"%s"}\n' "$action" "$repo" "$1"
  else
    printf '%s\n' "$1"
  fi
}

run_cmd() {
  if [[ "$dry_run" == "true" ]]; then
    printf 'dry-run:'
    printf ' %q' "$@"
    printf '\n'
    return 0
  fi
  (cd "$repo" && "$@")
}

require_file() {
  if [[ ! -f "$repo/$1" ]]; then
    emit "missing $1 in $repo"
    exit 1
  fi
}

case "$action" in
  doctor)
    require_file raycast/install.sh
    require_file raycast/quick-reply.js
    require_file raycast/context-reply.js
    require_file raycast/voice-note-raycast.js
    if command -v osascript >/dev/null 2>&1; then
      emit "osascript available"
    else
      emit "osascript not found"
    fi
    run_cmd node --check "$repo/raycast/quick-reply.js"
    run_cmd node --check "$repo/raycast/context-reply.js"
    run_cmd node --check "$repo/raycast/voice-note-raycast.js"
    ;;
  setup|sync)
    require_file raycast/install.sh
    run_cmd bash "$repo/raycast/install.sh" "${passthrough[@]}"
    ;;
  smoke)
    require_file raycast/test-microphone.sh
    run_cmd bash "$repo/raycast/test-microphone.sh" "${passthrough[@]}"
    ;;
  *)
    emit "unknown action '$action'"
    exit 1
    ;;
esac
