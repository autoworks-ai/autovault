#!/usr/bin/env bash
set -euo pipefail

action="${1:-audit}"
if [[ $# -gt 0 ]]; then
  shift
fi

repo="."
subject=""
dry_run="false"
json="false"
passthrough=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)
      repo="${2:?--repo requires a path}"
      shift 2
      ;;
    --subject)
      subject="${2:?--subject requires text}"
      shift 2
      ;;
    --dry-run)
      dry_run="true"
      shift
      ;;
    --json)
      json="true"
      shift
      ;;
    --)
      shift
      passthrough+=("$@")
      break
      ;;
    *)
      passthrough+=("$1")
      shift
      ;;
  esac
done

repo="$(cd "$repo" && pwd)"
workflow="$repo/workflows/daily/autojack-blog.md"

emit() {
  if [[ "$json" == "true" ]]; then
    printf '{"skill":"autojack-blog-publisher","action":"%s","repo":"%s","message":"%s"}\n' "$action" "$repo" "$1"
  else
    printf '%s\n' "$1"
  fi
}

require_file() {
  if [[ ! -f "$1" ]]; then
    emit "missing $1"
    exit 1
  fi
}

run_repo_cmd() {
  (cd "$repo" && "$@")
}

require_file "$workflow"
require_file "$repo/scripts/run-workflow-cli.js"

case "$action" in
  audit)
    require_file "$repo/scripts/lint-workflows.js"
    run_repo_cmd node "$repo/scripts/lint-workflows.js" "$workflow" "${passthrough[@]}"
    ;;
  dry-run)
    args=(--path "$workflow" --mode emit_prompt)
    if [[ -n "$subject" ]]; then
      args+=(--var "blog_subject=$subject")
    fi
    run_repo_cmd node "$repo/scripts/run-workflow-cli.js" "${args[@]}" "${passthrough[@]}"
    ;;
  run)
    if [[ "$dry_run" == "true" ]]; then
      args=(--path "$workflow" --mode emit_prompt)
    else
      args=(--path "$workflow" --mode agent --summary)
    fi
    if [[ -n "$subject" ]]; then
      args+=(--var "blog_subject=$subject")
    fi
    run_repo_cmd node "$repo/scripts/run-workflow-cli.js" "${args[@]}" "${passthrough[@]}"
    ;;
  *)
    emit "unknown action '$action'"
    exit 1
    ;;
esac
