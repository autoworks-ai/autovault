AUTOVAULT_MODE=local
AUTOVAULT_STORAGE_PATH=~/.autovault
# Optional: defaults to $AUTOVAULT_STORAGE_PATH/autovault.sqlite.
# AUTOVAULT_DB_PATH=~/.autovault/autovault.sqlite
AUTOVAULT_SECURITY_STRICT=true
AUTOVAULT_SEARCH_MODE=text
AUTOVAULT_LOG_LEVEL=info
# Remote service mode (Docker/Railway):
# AUTOVAULT_MODE=remote
# AUTOVAULT_STORAGE_PATH=/data/autovault
# AUTOVAULT_PUBLIC_URL=https://your-service.up.railway.app
# AUTOVAULT_HTTP_PORT=3000
# AUTOVAULT_ALLOWED_ORIGINS=https://your-mcp-client.example
# AUTOVAULT_ADMIN_EMAIL=admin@example.com
# AUTOVAULT_ADMIN_PASSWORD=replace-with-a-long-random-password
# Optional: supply a token for higher GitHub API rate limits.
# GITHUB_TOKEN=
# Optional: override the agentskills.io base API URL (used by the agentskills source).
# AUTOVAULT_AGENTSKILLS_BASE=https://agentskills.io/api/v1
