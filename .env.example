AUTOVAULT_MODE=local
AUTOVAULT_STORAGE_PATH=~/.autovault
AUTOVAULT_SECURITY_STRICT=true
AUTOVAULT_SEARCH_MODE=text
AUTOVAULT_LOG_LEVEL=info
# Optional: supply a token for higher GitHub API rate limits.
# GITHUB_TOKEN=
# Optional: override the agentskills.io base API URL (used by the agentskills source).
# AUTOVAULT_AGENTSKILLS_BASE=https://agentskills.io/api/v1
